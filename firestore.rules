rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        'email' in request.auth.token &&
        request.auth.token.email in [
          'aviroopghosh283@gmail.com',
          'hello@dualdeer.com'
        ];
    }

    match /orders/{orderId} {
      allow create: if true;

      // Allow anyone with the exact unguessable order ID to view their success page
      allow get: if true;

      allow list: if (
        request.auth != null &&
        resource.data.userId == request.auth.uid
      ) || isAdmin();

      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.userId == request.auth.uid &&
        (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason']) &&
            resource.data.status == 'processing' &&
            request.resource.data.status == 'cancellation_requested'
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'returnReason']) &&
            resource.data.status == 'delivered' &&
            request.resource.data.status == 'return_requested'
          )
        )
      );

      allow delete: if isAdmin() || (
        request.auth != null &&
        resource.data.userId == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read, write: if (
        request.auth != null &&
        request.auth.uid == userId
      ) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAdmin() ||
        (request.auth != null &&
         resource.data.userId == request.auth.uid);

      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.userId == request.auth.uid);

      allow update: if isAdmin() ||
        (request.auth != null &&
         resource.data.userId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /wishlists/{docId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow read, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /ai_memory/{docId} {
      allow read, write: if true;
    }

    match /user_memory/{docId} {
      allow read, write: if true;
    }

    match /global_knowledge_v2/{docId} {
      allow read, write: if true;
    }

    match /reaction_scores_v2/{scoreId} {
      allow read: if true;

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /reaction_leaderboard/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null && 
                    request.resource.data.score is int &&
                    request.resource.data.score > 0 &&
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if
        request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;

      allow update, delete: if
        isAdmin() ||
        (
          request.auth != null &&
          resource.data.userId == request.auth.uid
        );
    }

    match /coupons/{couponId} {
      allow read: if true;

      allow create: if isAdmin() || (
        request.auth != null && 
        request.resource.data.affiliateId == request.auth.uid
      );

      allow update: if isAdmin() || (
        request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(['usedBy'])
      );

      allow delete: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /emailQueue/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /projectX_bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{userId} {
      allow get: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow list: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /withdrawal_requests/{docId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.affiliateId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.affiliateId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /affiliate_codes/{codeId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid 
                    && !exists(/databases/$(database)/documents/affiliate_codes/$(codeId));
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /upcomingProducts/{docId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyCount']) &&
        request.resource.data.notifyCount == resource.data.notifyCount + 1
      );
    }

    match /productNotifications/{notificationId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
